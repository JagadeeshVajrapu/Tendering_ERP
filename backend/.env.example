NODE_ENV=development
PORT=5001

# MongoDB
MONGODB_URI=mongodb://localhost:27017/tender-erp

# Auth
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:3002
# CORS_ORIGINS=http://localhost:3002,http://192.168.1.10:3002

# File uploads
UPLOADS_DIR=
UPLOAD_MAX_FILE_SIZE_MB=25

# AWS S3 + Textract
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=tender-erp-documents

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_ENABLED=true
OPENAI_FALLBACK_ON_ERROR=true

# Google Gemini (optional)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_ENABLED=false

# Redis + BullMQ
REDIS_ENABLED=true
REDIS_URL=redis://127.0.0.1:6379
REDIS_WORKER_CONCURRENCY=3

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@tendererp.com

# Company profile
COMPANY_TURNOVER=50000000
COMPANY_EXPERIENCE_YEARS=10
COMPANY_HAS_ISO=true
COMPANY_IS_MSME=false
COMPANY_HAS_GST=true
COMPANY_HAS_PAN=true

# Intelligence pipeline
INTELLIGENCE_CHUNK_PAGES=5
INTELLIGENCE_CHUNK_CONCURRENCY=6
INTELLIGENCE_FIELD_CONCURRENCY=8
INTELLIGENCE_PAGE_CONCURRENCY=6
INTELLIGENCE_CONFIDENCE_THRESHOLD=0.55
OCR_MIN_QUALITY_SCORE=70
PIPELINE_CACHE_ENABLED=true
CACHE_TTL_OCR_SECONDS=86400
CACHE_TTL_OPENAI_SECONDS=604800
